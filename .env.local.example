# FamilyXYZ - Local Development Environment Template
# Copy to .env.local and fill in your values
# This file is gitignored - safe for personal secrets

#####################################
# VPS/Server Configuration (Optional)
#####################################
# Your Hetzner VPS hostname or IP
# VPS_HOSTNAME=snel-bot
# VPS_IP=157.180.36.156
# VPS_USER=deploy
# VPS_SSH_PORT=22
# VPS_SSH_KEY=~/.ssh/id_ed25519

#####################################
# API Keys (Required for Production)
#####################################

# Venice AI (Primary LLM Provider)
VENICE_API_KEY=your-venice-api-key-here

# OpenAI (Fallback/Alternative)
# OPENAI_API_KEY=your-openai-api-key-here

# Hedera Hashgraph (Blockchain)
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=your-hedera-private-key-here

# Optional: Hedera Topic/Token IDs (if already created)
# HEDERA_WISDOM_TOPIC_ID=0.0.xxxxx
# HEDERA_FAMILY_TOKEN_ID=0.0.xxxxx
# HEDERA_TREASURY_ACCOUNT_ID=0.0.xxxxx

#####################################
# Optional: Other AI Providers
#####################################
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# LLAMALOCAL_URL=

#####################################
# Database (Optional - defaults to SQLite)
#####################################
# DATABASE_URL=postgresql://user:pass@localhost:5432/familexyz
# REDIS_URL=redis://localhost:6379

#####################################
# Feature Flags
#####################################
# HEDERA_ENABLE_CONSENSUS=true
# HEDERA_SUBMIT_STARTUP_TEST=true
