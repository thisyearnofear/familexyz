# FamilyXYZ - Minimal Production Environment
# Copy to .env and fill in your values

# Server Configuration
NODE_ENV=production
SERVER_PORT=3004
HEALTH_PORT=3005

# Model Provider (choose one)
MODEL_PROVIDER=venice
# VENICE_API_KEY=your-venice-api-key

# Or use OpenAI
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key

# Hedera Configuration (testnet)
HEDERA_NETWORK=testnet
# HEDERA_OPERATOR_ID=0.0.xxxxx
# HEDERA_OPERATOR_KEY=your-private-key

# Optional: Hedera Topic/Token IDs (if already created)
# HEDERA_WISDOM_TOPIC_ID=0.0.xxxxx
# HEDERA_FAMILY_TOKEN_ID=0.0.xxxxx

# Character Configuration
CHARACTER_PATHS=/app/characters/wisdom.character.json,/app/characters/intimacy.character.json,/app/characters/generationalBridge.character.json,/app/characters/presence.character.json,/app/characters/growth.character.json

# Logging
DEFAULT_LOG_LEVEL=info
