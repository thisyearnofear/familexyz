{
    "name": "@familexyz/agent",
    "version": "1.0.0-beta",
    "description": "FamilyXYZ AI agent backend - Five specialized family connection agents",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "start": "node --import tsx src/index.ts --characters=../characters/wisdom.character.json,../characters/intimacy.character.json,../characters/generationalBridge.character.json,../characters/presence.character.json,../characters/growth.character.json",
        "dev": "node --import tsx src/index.ts",
        "check-types": "tsc --noEmit",
        "test": "jest"
    },
    "nodemonConfig": {
        "watch": [
            "src",
            "../core/dist"
        ],
        "ext": "ts,json",
        "exec": "node --enable-source-maps --loader ts-node/esm src/index.ts"
    },
    "dependencies": {
        "@familexyz/agent": "workspace:*",
        "@elizaos/adapter-pglite": "workspace:*",
        "@elizaos/adapter-postgres": "workspace:*",
        "@elizaos/adapter-qdrant": "workspace:*",
        "@elizaos/adapter-redis": "workspace:*",
        "@elizaos/adapter-sqlite": "workspace:*",
        "@elizaos/adapter-supabase": "workspace:*",
        "@elizaos/client-direct": "workspace:*",
        "@elizaos/config": "workspace:*",
        "@elizaos/core": "workspace:*",
        "@elizaos/family/plugin-generational-bridge": "workspace:*",
        "@elizaos/family/plugin-growth": "workspace:*",
        "@elizaos/family/plugin-intimacy": "workspace:*",
        "@elizaos/family/plugin-presence": "workspace:*",
        "@elizaos/family/plugin-savings": "workspace:*",
        "@elizaos/family/plugin-wisdom": "workspace:*",
        "@elizaos/hedera-core": "workspace:*",
        "readline": "1.3.0",
        "ws": "8.18.0",
        "yargs": "17.7.2"
    },
    "devDependencies": {
        "@jest/globals": "30.2.0",
        "@types/jest": "^29.5.14",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "ts-node": "10.9.2",
        "tsup": "8.3.5"
    }
}
