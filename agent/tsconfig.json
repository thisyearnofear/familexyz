{
    "compilerOptions": {
        "outDir": "dist",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "types": [
            "node",
            "jest"
        ],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": false,
        "noEmit": true,
        "baseUrl": "../",
        "paths": {
            "@elizaos/config": [
                "packages/config/dist/index.js"
            ],
            "@elizaos/core": [
                "packages/core/dist/index.js"
            ],
            "@elizaos/hedera-core": [
                "packages/blockchain/hedera-core/dist/index.js"
            ],
            "@elizaos/plugin-node": [
                "packages/plugin-node/dist/index.js"
            ],
            "@elizaos/family/plugin-*": [
                "packages/family/plugin-*/dist/index.js"
            ],
            "@elizaos/family-nlp-utils": [
                "packages/family/nlp-utils/dist/index.js"
            ],
            "@familexyz/agent-services": [
                "packages/agent/dist/index.js"
            ],
            "@elizaos/adapter-*": [
                "packages/adapters/*/dist/index.js"
            ],
            "@elizaos/client-*": [
                "packages/clients/*/dist/index.js"
            ]
        }
    },
    "ts-node": {
        "experimentalSpecifierResolution": "node",
        "transpileOnly": true,
        "esm": true
    },
    "include": [
        "src/**/*",
        "../packages/*/dist/**/*.d.ts",
        "../packages/blockchain/hedera-core/dist/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}