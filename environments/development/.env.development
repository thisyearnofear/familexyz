# Family-Connection AI Agents - Development Environment
# Copy this file to .env.local and customize for your development setup

# =============================================================================
# CORE CONFIGURATION
# =============================================================================
NODE_ENV=development
VERBOSE=true
DEFAULT_LOG_LEVEL=debug
DEBUG=eliza:*

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# SQLite (default for development)
DATABASE_URL=sqlite:./agent/data/db.sqlite

# PostgreSQL (alternative)
# DATABASE_URL=postgresql://username:password@localhost:5432/family_agents_dev

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Anthropic Configuration (alternative)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Model Configuration (Ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama2

# =============================================================================
# SOCIAL PLATFORM CLIENTS
# =============================================================================
# Discord Bot Configuration
DISCORD_APPLICATION_ID=your_discord_app_id
DISCORD_API_TOKEN=your_discord_bot_token

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Twitter/X API Configuration
TWITTER_DRY_RUN=true
TWITTER_USERNAME=your_bot_username
TWITTER_PASSWORD=your_bot_password
TWITTER_EMAIL=your_bot_email

# =============================================================================
# FAMILY-SPECIFIC FEATURES
# =============================================================================
# Generational Bridge Settings
GENERATIONAL_BRIDGE_ENABLED=true
STORY_GENERATION_MODEL=gpt-4

# Intimacy Coach Settings
INTIMACY_COACH_ENABLED=true
RELATIONSHIP_ASSESSMENT_INTERVAL=weekly

# Growth Challenge Settings
GROWTH_CHALLENGES_ENABLED=true
DAILY_CHALLENGE_TIME=09:00

# Presence & Mindfulness Settings
MINDFULNESS_REMINDERS_ENABLED=true
PRESENCE_CHECK_INTERVAL=30m

# Wisdom Sharing Settings
WISDOM_SHARING_ENABLED=true
PHILOSOPHICAL_MODE=socratic

# =============================================================================
# BLOCKCHAIN CONFIGURATION (HEDERA)
# =============================================================================
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=your_testnet_account_id
HEDERA_PRIVATE_KEY=your_testnet_private_key

# =============================================================================
# SECURITY & PRIVACY
# =============================================================================
# JWT Secret for authentication
JWT_SECRET=your_development_jwt_secret_here

# Encryption key for sensitive data
ENCRYPTION_KEY=your_32_character_encryption_key

# Privacy mode (higher security for family data)
PRIVACY_MODE=strict
DATA_RETENTION_DAYS=90

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Image Generation (for family memories)
STABILITY_API_KEY=your_stability_ai_key

# Speech/TTS Services
DEEPGRAM_API_KEY=your_deepgram_key

# Weather API (for activity suggestions)
OPENWEATHER_API_KEY=your_openweather_key

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Hot reload and development features
HOT_RELOAD=true
ENABLE_DEBUGGING=true
MOCK_EXTERNAL_APIS=false

# Test data and fixtures
USE_TEST_DATA=true
SEED_DATABASE=true

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true

# Sentry for error tracking (optional)
# SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# CLIENT CONFIGURATION
# =============================================================================
CLIENT_PORT=3000
CLIENT_HOST=localhost
API_BASE_URL=http://localhost:3000

# WebSocket configuration
WS_PORT=3001
ENABLE_WEBSOCKETS=true

# =============================================================================
# RATE LIMITING & PERFORMANCE
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
MAX_CONCURRENT_CONVERSATIONS=10
RESPONSE_TIMEOUT_MS=30000

# =============================================================================
# FAMILY SAFETY FEATURES
# =============================================================================
CONTENT_MODERATION_ENABLED=true
PARENTAL_CONTROLS_ENABLED=true
SAFE_MODE=true

# Age-appropriate content filtering
MIN_USER_AGE=13
ENABLE_FAMILY_FILTER=true
