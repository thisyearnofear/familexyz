# Family-Connection AI Agents - Development Environment
# Copy this file to .env and customize for your development setup

# =============================================================================
# CORE CONFIGURATION
# =============================================================================
NODE_ENV=development
VERBOSE=true
DEFAULT_LOG_LEVEL=debug
DEBUG=eliza:*
SERVER_PORT=3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# SQLite (default for development)
DATABASE_URL=sqlite:./data/family_agents.db
CACHE_STORE=database

# PostgreSQL (alternative)
# DATABASE_URL=postgresql://username:password@localhost:5432/family_agents_dev

# =============================================================================
# AI MODEL CONFIGURATION (PRIVACY-FIRST WITH VENICE)
# =============================================================================
# Venice Configuration (PRIMARY - Privacy-focused for families)
# Get your API key from: https://api.venice.ai/ -> Settings -> API Keys
VENICE_API_KEY=dIc30f3ibGlNEuZs-HiSMK4KRJVXP-Whsme-KpdOoG
SMALL_VENICE_MODEL=llama-3.3-70b
MEDIUM_VENICE_MODEL=llama-3.3-70b
LARGE_VENICE_MODEL=llama-3.1-405b
IMAGE_VENICE_MODEL=fluently-xl

# OpenAI Configuration (FALLBACK - for compatibility)
OPENAI_API_KEY=your_openai_api_key_here
SMALL_OPENAI_MODEL=gpt-4o-mini
MEDIUM_OPENAI_MODEL=gpt-4o
LARGE_OPENAI_MODEL=gpt-4o
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
USE_OPENAI_EMBEDDING=FALSE

# Anthropic Configuration (alternative fallback)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Model Configuration (Ollama - for offline privacy)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama2

# =============================================================================
# SOCIAL PLATFORM CLIENTS
# =============================================================================
# Discord Bot Configuration
DISCORD_APPLICATION_ID=your_discord_app_id
DISCORD_API_TOKEN=your_discord_bot_token

# Telegram Bot Configuration (READY FOR DEMO!)
# Your Family AI Agents Bot: @familexyzbot
TELEGRAM_BOT_TOKEN=8369925666:AAE91ZKO3RAi8-cRYwykmjd4Jv4j-Vi9ONY

# Twitter/X API Configuration
TWITTER_DRY_RUN=true
TWITTER_USERNAME=your_bot_username
TWITTER_PASSWORD=your_bot_password
TWITTER_EMAIL=your_bot_email

# =============================================================================
# FAMILY-SPECIFIC FEATURES (PRIVACY-ENHANCED)
# =============================================================================
# Generational Bridge Settings
GENERATIONAL_BRIDGE_ENABLED=true
STORY_GENERATION_MODEL=llama-3.3-70b
STORY_PRIVACY_MODE=strict

# Intimacy Coach Settings
INTIMACY_COACH_ENABLED=true
RELATIONSHIP_ASSESSMENT_INTERVAL=weekly
INTIMACY_PRIVACY_LEVEL=maximum

# Growth Challenge Settings
GROWTH_CHALLENGES_ENABLED=true
DAILY_CHALLENGE_TIME=09:00
FAMILY_GOAL_PRIVACY=private

# Presence & Mindfulness Settings
MINDFULNESS_REMINDERS_ENABLED=true
PRESENCE_CHECK_INTERVAL=30m
MINDFULNESS_DATA_LOCAL=true

# Wisdom Sharing Settings
WISDOM_SHARING_ENABLED=true
PHILOSOPHICAL_MODE=socratic
WISDOM_CONVERSATIONS_ENCRYPTED=true

# =============================================================================
# BLOCKCHAIN CONFIGURATION (HEDERA)
# =============================================================================
HEDERA_NETWORK=testnet
# Replace with your actual Hedera testnet account (get from https://portal.hedera.com/)
HEDERA_ACCOUNT_ID=0.0.your_account_id
HEDERA_PRIVATE_KEY=your_testnet_private_key

# HashConnect Configuration (for wallet demo)
HASHCONNECT_PROJECT_ID=family-ai-agents
HASHCONNECT_APP_NAME=Family AI Agents
HASHCONNECT_APP_DESCRIPTION=Privacy-first AI agents for family wellness on Hedera
HASHCONNECT_APP_URL=https://famile.xyz
HASHCONNECT_APP_ICONS=["https://famile.xyz/icon.png"]

# =============================================================================
# SECURITY & PRIVACY (ENHANCED FOR FAMILIES)
# =============================================================================
# JWT Secret for authentication
JWT_SECRET=family_ai_agents_secure_jwt_secret_2024_hackathon_demo

# Encryption key for sensitive data
ENCRYPTION_KEY=family_agents_encryption_key_32ch

# Privacy mode (maximum security for family data)
PRIVACY_MODE=maximum
DATA_RETENTION_DAYS=90
LOCAL_DATA_PROCESSING=true
ZERO_LOG_POLICY=true

# Family safety settings
CONTENT_MODERATION_ENABLED=true
PARENTAL_CONTROLS_ENABLED=true
SAFE_MODE=true
MIN_USER_AGE=13
ENABLE_FAMILY_FILTER=true
CONVERSATION_ENCRYPTION=true

# =============================================================================
# VENICE-SPECIFIC PRIVACY SETTINGS
# =============================================================================
# Venice privacy parameters
VENICE_ENABLE_WEB_SEARCH=false
VENICE_INCLUDE_SYSTEM_PROMPT=true
VENICE_SAFE_MODE=true
VENICE_HIDE_WATERMARK=true
VENICE_PRIVACY_MODE=strict

# =============================================================================
# EXTERNAL SERVICES (PRIVACY-CONSCIOUS)
# =============================================================================
# Image Generation (privacy-focused)
# Use Venice for image generation instead of external services
USE_VENICE_IMAGE_GENERATION=true

# Speech/TTS Services (optional - consider privacy implications)
# DEEPGRAM_API_KEY=your_deepgram_key
# ELEVENLABS_XI_API_KEY=your_elevenlabs_key

# Weather API (for activity suggestions)
# OPENWEATHER_API_KEY=your_openweather_key

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Hot reload and development features
HOT_RELOAD=true
ENABLE_DEBUGGING=true
MOCK_EXTERNAL_APIS=false

# Test data and fixtures
USE_TEST_DATA=false
SEED_DATABASE=true

# =============================================================================
# LOGGING & MONITORING (PRIVACY-COMPLIANT)
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=pretty
ENABLE_REQUEST_LOGGING=true
LOG_PERSONAL_DATA=false
ANONYMIZE_LOGS=true

# Sentry for error tracking (optional - ensure privacy compliance)
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_SCRUB_PII=true

# =============================================================================
# CLIENT CONFIGURATION
# =============================================================================
CLIENT_PORT=3000
CLIENT_HOST=localhost
API_BASE_URL=http://localhost:3000

# WebSocket configuration
WS_PORT=3001
ENABLE_WEBSOCKETS=true

# =============================================================================
# RATE LIMITING & PERFORMANCE
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
MAX_CONCURRENT_CONVERSATIONS=10
RESPONSE_TIMEOUT_MS=30000

# =============================================================================
# CHARACTER CONFIGURATION
# =============================================================================
# Use the family character configurations
USE_CHARACTER_STORAGE=true
REMOTE_CHARACTER_URLS=

# =============================================================================
# DEMO-SPECIFIC SETTINGS
# =============================================================================
# Enable features that showcase family AI agents
DEMO_MODE=true
SHOW_AGENT_SELECTION=true
ENABLE_FAMILY_ONBOARDING=true
FAMILY_TOPIC_CREATION=true
PRIVACY_DEMO_MODE=true
