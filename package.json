{
    "name": "familexyz",
    "version": "1.0.0-beta",
    "description": "AI-powered family connection platform with five specialized family agents - Cache cleared for mega nuclear deployment",
    "keywords": [
        "family",
        "AI agents",
        "relationships",
        "communication",
        "emotional intelligence"
    ],
    "author": "FamilyXYZ Team",
    "license": "MIT",
    "homepage": "https://familexyz.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-org/familexyz.git"
    },
    "scripts": {
        "format": "biome format --write . --config-path config/biome.json",
        "lint": "biome lint . --config-path config/biome.json",
        "check": "biome check --apply . --config-path config/biome.json",
        "preinstall": "npx only-allow pnpm",
        "build": "turbo run build",
        "build:client": "pnpm --filter client build",
        "build-docker": "turbo run build",
        "cleanstart": "if [ -f agent/data/db.sqlite ]; then rm agent/data/db.sqlite; fi && pnpm --filter \"@elizaos/agent\" start --isRoot",
        "cleanstart:debug": "if [ -f agent/data/db.sqlite ]; then rm agent/data/db.sqlite; fi && cross-env NODE_ENV=development VERBOSE=true DEFAULT_LOG_LEVEL=debug DEBUG=eliza:* pnpm --filter \"@elizaos/agent\" start --isRoot",
        "start": "pnpm --filter \"@elizaos/client-direct\" start",
        "start:client": "pnpm --dir client dev",
        "start:family": "bash ./scripts/start-family-agents.sh",
        "start:debug": "cross-env NODE_ENV=development VERBOSE=true DEFAULT_LOG_LEVEL=debug DEBUG=eliza:* pnpm --filter \"@elizaos/agent\" start --isRoot",
        "dev": "pnpm --filter \"@elizaos/client-direct\" dev",
        "dev:old": "bash ./scripts/dev.sh",
        "release": "pnpm build && pnpm format && npx lerna publish --no-private --force-publish",
        "clean": "bash ./scripts/clean.sh",
        "docker:build": "bash ./scripts/docker.sh build",
        "docker:run": "bash ./scripts/docker.sh run",
        "docker:bash": "bash ./scripts/docker.sh bash",
        "docker:start": "bash ./scripts/docker.sh start",
        "docker": "pnpm docker:build && pnpm docker:run && pnpm docker:bash",
        "test": "bash ./scripts/test.sh",
        "smokeTests": "bash ./scripts/smokeTests.sh",
        "integrationTests": "bash ./scripts/integrationTests.sh"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@commitlint/cli": "18.6.1",
        "@commitlint/config-conventional": "18.6.3",
        "@hashgraph/sdk": "2.77.0",
        "@types/bs58": "^5.0.0",
        "@types/jest": "^29.5.11",
        "@types/node": "^22",
        "concurrently": "9.1.0",
        "cross-env": "7.0.3",
        "husky": "9.1.7",
        "jest": "^29.7.0",
        "lerna": "8.1.5",
        "only-allow": "1.2.1",
        "tsx": "4.20.6",
        "turbo": "2.3.3",
        "typedoc": "0.26.11",
        "typescript": "5.6.3",
        "viem": "2.21.58",
        "vite": "5.4.12",
        "vitest": "2.1.5"
    },
    "pnpm": {
        "overrides": {
            "esbuild": "0.24.2",
            "onnxruntime-node": "1.20.1",
            "viem": "2.21.58",
            "@polkadot/util": "12.6.2",
            "@polkadot/util-crypto": "12.6.2",
            "@polkadot/types-create": "10.13.1",
            "@polkadot/types-codec": "10.13.1"
        }
    },
    "engines": {
        "node": ">=22 <23"
    },
    "dependencies": {
        "@0glabs/0g-ts-sdk": "0.2.1",
        "@coinbase/coinbase-sdk": "0.10.0",
        "@deepgram/sdk": "^3.9.0",
        "@injectivelabs/sdk-ts": "^1.14.33",
        "@rollup/rollup-darwin-x64": "4.59.0",
        "@vitest/eslint-plugin": "1.0.1",
        "amqplib": "0.10.5",
        "better-sqlite3": "9.6.0",
        "bs58": "4.0.0",
        "csv-parse": "5.6.0",
        "dotenv": "^17.2.1",
        "fsevents": "^2.3.2",
        "langdetect": "^0.2.1",
        "node-telegram-bot-api": "^0.66.0",
        "ollama-ai-provider": "0.16.1",
        "optional": "0.1.4",
        "pnpm": "9.14.4",
        "sharp": "0.33.5",
        "tslog": "4.9.3",
        "uuid": "^9.0.1"
    },
    "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee",
    "workspaces": [
        "packages/*"
    ],
    "resolutions": {
        "fsevents": "2.3.2"
    }
}
