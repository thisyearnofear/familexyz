{
    "name": "@elizaos/hedera-wallet",
    "version": "0.1.0",
    "description": "Hedera-native wallet authentication and session management for ElizaOS family platforms",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "hedera",
        "hashconnect",
        "walletconnect",
        "authentication",
        "family",
        "elizaos"
    ],
    "scripts": {
        "build": "tsup 'src/**/*.ts' --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "clean": "rm -rf dist",
        "test": "jest",
        "lint": "eslint src --ext .ts",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@hashgraph/sdk": "^2.49.0",
        "hashconnect": "^3.0.13",
        "@hashgraph/hedera-wallet-connect": "^1.5.1",
        "@walletconnect/sign-client": "^2.11.0",
        "@walletconnect/utils": "^2.11.0",
        "zustand": "^4.4.7",
        "immer": "^10.0.3",
        "zod": "^3.22.4"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "^20.10.5",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "typescript": "^5.3.3",
        "tsup": "^8.0.1",
        "jest": "^29.7.0",
        "@types/jest": "^29.5.8",
        "eslint": "^8.56.0",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.js",
            "require": "./dist/react.cjs"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/types/index.js",
            "require": "./dist/types/index.cjs"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/elizaOS/eliza.git",
        "directory": "packages/auth/hedera-wallet"
    },
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    }
}
