{
  "name": "@elizaos/hedera-core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "@elizaos/source": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./services": {
      "import": {
        "@elizaos/source": "./src/services/index.ts",
        "types": "./dist/services/index.d.ts",
        "default": "./dist/services/index.js"
      },
      "require": {
        "types": "./dist/services/index.d.ts",
        "default": "./dist/services/index.cjs"
      }
    },
    "./types": {
      "import": {
        "@elizaos/source": "./src/types/index.ts",
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.cjs"
      }
    },
    "./utils": {
      "import": {
        "@elizaos/source": "./src/utils/index.ts",
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      },
      "require": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@hashgraph/hedera-agent-kit": "4.0.0",
    "@hashgraph/hedera-agent-kit-elizaos": "1.0.0",
    "@hashgraph/sdk": "^2.49.2",
    "@hashgraphonline/standards-sdk": "0.1.126",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "ts-node": "10.9.2",
    "tsup": "^8.3.5",
    "tsx": "^4.0.0",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "build": "tsup 'src/**/*.ts' --format esm,cjs --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "clean": "rm -rf dist",
    "test": "tsx test/test-runner.ts",
    "smoke:e2e": "tsx test/e2e-smoke.ts"
  },
  "private": true
}
