{
  "name": "@elizaos/family-plugin-hedera-template",
  "version": "0.1.0",
  "description": "Enhanced family plugin template with Hedera blockchain integration for sentiment tracking and token rewards",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "@elizaos/source": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs",
    "dev": "tsup --format esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/family-nlp-utils": "workspace:*",
    "@elizaos/hedera-core": "workspace:*",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "keywords": [
    "eliza",
    "family",
    "hedera",
    "blockchain",
    "sentiment",
    "nlp",
    "ai",
    "agent",
    "plugin"
  ],
  "author": "ElizaOS",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  }
}
