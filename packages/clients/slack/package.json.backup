{
    "name": "@elizaos/client-slack",
    "version": "0.1.9-alpha.1",
    "description": "Slack client plugin for Eliza framework",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "@elizaos/source": "./src/index.ts",
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "echo 'Skipping build for disabled Slack client'",
        "test": "echo 'Skipping test for disabled Slack client'",
        "test:watch": "echo 'Skipping test:watch for disabled Slack client'",
        "clean": "echo 'Skipping clean for disabled Slack client'",
        "dev": "echo 'Skipping dev for disabled Slack client'",
        "example": "echo 'Skipping example for disabled Slack client'",
        "example:attachment": "echo 'Skipping example:attachment for disabled Slack client'",
        "example:summarize": "echo 'Skipping example:summarize for disabled Slack client'",
        "example:transcribe": "echo 'Skipping example:transcribe for disabled Slack client'"
    },
    "dependencies": {
        "@elizaos/core": "workspace:*",
        "bs58": "^6.0.0",
        "@types/bs58": "^5.0.0",
        "dotenv": "^16.0.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/fluent-ffmpeg": "^2.1.24",
        "@types/node": "^18.15.11",
        "rimraf": "^5.0.0",
        "tsup": "^6.7.0",
        "typescript": "^5.0.3",
        "vitest": "^1.2.1"
    },
    "engines": {
        "node": ">=14.0.0"
    }
}
