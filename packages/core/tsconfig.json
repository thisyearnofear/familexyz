{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "allowImportingTsExtensions": true,
        "noEmit": false,
        "declaration": true,
        "emitDeclarationOnly": false,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strictPropertyInitialization": false,
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "exactOptionalPropertyTypes": false,
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "noEmitOnError": false,
        "moduleDetection": "force",
        "allowArbitraryExtensions": false,
        "customConditions": [
            "@elizaos/source"
        ],
        "composite": true,
        "typeRoots": [],
        "types": []
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/**/*.d.ts",
        "src/**/*.test.ts",
        "**/@types/aws-lambda",
        "**/@types/better-sqlite3",
        "**/@types/body-parser",
        "**/@types/chrome",
        "**/@types/cors",
        "**/@types/lodash",
        "**/@types/node-fetch",
        "**/@types/nodemailer",
        "**/@types/pdfjs-dist",
        "**/@types/pg",
        "**/@types/react",
        "**/@types/react-dom"
    ]
}