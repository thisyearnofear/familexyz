{
  "name": "@elizaos/family-plugin-wisdom",
  "version": "0.0.1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "private": true,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --no-dts"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/family-nlp-utils": "workspace:*",
    "@elizaos/hedera-core": "workspace:*",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
