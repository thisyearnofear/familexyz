{
  "name": "@elizaos/hedera-core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "@elizaos/source": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./services": {
      "import": {
        "@elizaos/source": "./src/services/index.ts",
        "types": "./dist/services/index.d.ts",
        "default": "./dist/services/index.js"
      }
    },
    "./types": {
      "import": {
        "@elizaos/source": "./src/types/index.ts",
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      }
    },
    "./utils": {
      "import": {
        "@elizaos/source": "./src/utils/index.ts",
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@hashgraph/sdk": "^2.49.2",
    "node-cache": "^5.1.2",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsup --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "private": true
}
