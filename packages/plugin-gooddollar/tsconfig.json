{
  "extends": "../../config/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": "../..",
    "typeRoots": ["node_modules/@types", "../../node_modules/@types"],
    "moduleResolution": "node",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}