{
    "extends": "../../config/tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": "../..",
        "typeRoots": [
            "node_modules/@types",
            "../../node_modules/@types"
        ],
        "moduleResolution": "NodeNext",
        "module": "NodeNext",
        "target": "ES2022",
        "declaration": true,
        "noEmit": false,
        "allowImportingTsExtensions": false,
        "types": [
            "node"
        ],
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}