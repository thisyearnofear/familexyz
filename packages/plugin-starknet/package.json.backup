        "starknet": "6.18.0",
        "tsup": "8.3.5",
        "vitest": "2.1.5"
    },
    "scripts": {
        "build": "echo 'Skipping build for disabled plugin-starknet plugin'",
        "dev": "echo 'Skipping dev for disabled plugin-starknet plugin'",
